# ---------------------------------------------------------------------------
# Tennoplan environment variables
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------------------

# Cloudflare Worker URL for worldstate delivery.
#
# How to set up:
#   1. cd cloudflare-worker
#   2. npm install
#   3. wrangler kv namespace create WORLDSTATE
#      → copy the returned `id` and `preview_id` into wrangler.toml
#   4. wrangler deploy
#      → copy the returned Worker URL below
#
# Without this variable, Tennoplan falls back to api.warframestat.us directly.
# This is fine for local dev but means every client hits warframestat.us at
# scale — set this before deploying to users.
#VITE_WORLDSTATE_WORKER_URL=https://tennoplan-worldstate.YOUR_SUBDOMAIN.workers.dev
