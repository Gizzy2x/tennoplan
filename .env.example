# ---------------------------------------------------------------------------
# Tennoplan environment variables
# Copy this file to .env and fill in your values.
# ---------------------------------------------------------------------------

# Cloudflare Worker URL for worldstate delivery.
#
# How to set up:
#   1. cd cloudflare-worker
#   2. npm install
#   3. wrangler kv namespace create WORLDSTATE
#      → copy the returned `id` and `preview_id` into wrangler.toml
#   4. wrangler deploy
#      → copy the returned Worker URL below
#
# REQUIRED. The V2 frontend talks only to the Worker — there is no direct
# warframestat.us fallback (the legacy SyncService was retired in Phase E).
# Without this variable, WorldstateSync.init() is a no-op and every tab
# renders empty.
VITE_WORLDSTATE_WORKER_URL=https://app.tennoplan.workers.dev
